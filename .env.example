# AEGIS Configuration
# Copy to .env and fill in values
# NEVER commit .env to git!

# === EXCHANGE DATA ===
# Yahoo Finance Direct API (no key needed)
YAHOO_BASE_URL=https://query1.finance.yahoo.com/v8/finance/chart
STOOQ_BASE_URL=https://stooq.com/q
DATA_CACHE_TTL_SECONDS=300

# === MARKETS ===
MY_MARKET_TICKERS_FILE=../tickers-department/my-tickers.json
US_MARKET_TICKERS_FILE=../tickers-department/us-tickers.json

# === SCAN DEFAULTS ===
DEFAULT_SCAN_INTERVAL=15m
COMPOSITE_THRESHOLD_BUY=50
COMPOSITE_THRESHOLD_WATCH=35
COMPOSITE_THRESHOLD_WEAK=20

# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === MOOMOO OpenD ===
MOOMOO_HOST=127.0.0.1
MOOMOO_PORT=11111
MOOMOO_TRADE_ENV=SIMULATE

# === TRADINGVIEW ===
TV_USERNAME=
TV_WEBHOOK_URL=

# === DASHBOARD ===
DASHBOARD_PORT=3100
DASHBOARD_HOST=localhost
