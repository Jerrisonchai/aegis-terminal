//@version=5
// Color-Coded EMA
// Green when price > EMA, Red when price < EMA
// Copy this into TradingView Pine Editor to test

indicator("Color-Coded EMA", overlay=true)

length = input.int(20, "EMA Length", minval=1)
emaLine = ta.ema(close, length)

// Color logic
bullish = close > emaLine
emaColor = bullish ? color.green : color.red

// Crossover signals
crossUp = ta.crossover(close, emaLine)
crossDown = ta.crossunder(close, emaLine)

plot(emaLine, color=emaColor, linewidth=2, title="EMA")

plotshape(crossUp, title="Buy Signal", location=location.belowbar,
  color=color.green, style=shape.triangleup, size=size.small)

plotshape(crossDown, title="Sell Signal", location=location.abovebar,
  color=color.red, style=shape.triangledown, size=size.small)

// Alert conditions
alertcondition(crossUp, title="EMA Cross Up", message="Price crossed above EMA")
alertcondition(crossDown, title="EMA Cross Down", message="Price crossed below EMA")
